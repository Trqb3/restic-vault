# ── Required ──────────────────────────────────────────────────────────────────

# Secret for signing JWT tokens (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# AES-256-GCM key for encrypting repo passwords (must be 32+ characters)
SECRET_KEY=change-me-to-a-32-char-or-longer-secret

# ── Optional ──────────────────────────────────────────────────────────────────

# Host path to your restic backup repositories (mounted read-only into /repos)
HOST_REPO_DIR=/srv/restic-repos

# Override the default base directory inside the container (default: /repos)
# REPO_BASE_DIR=/repos

# Override the backend port (default: 3001)
# PORT=3001

# Override the restic binary path inside the container (default: restic)
# RESTIC_BINARY=restic

# ── Backup Sources ─────────────────────────────────────────────────────────────

# Public-facing URL of your ResticVault instance (used in agent install commands)
# No trailing slash. Example: https://vault.example.com
# PUBLIC_URL=https://vault.example.com

# Directory where backup-source restic repositories are stored (must be writable)
# Default: same directory as DB_PATH, in a "sources" subdirectory
# SOURCES_DIR=/data/sources

# Path to the rest-server binary (enables the Backup Sources push-backup feature)
# Download from: https://github.com/restic/rest-server/releases
# REST_SERVER_BINARY=rest-server

# Port the embedded rest-server listens on (localhost only, not exposed externally)
# REST_SERVER_PORT=8079
